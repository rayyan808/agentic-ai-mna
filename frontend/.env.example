# ── Anthropic ────────────────────────────────────────────────────────────────
# No VITE_ prefix — this key is used only in vite.config.js (server-side proxy)
# and is NEVER bundled into the browser.
ANTHROPIC_API_KEY=sk-ant-...

# ── Chromia blockchain ────────────────────────────────────────────────────────
# VITE_ prefix means these values are available in the browser bundle.
# Both are safe to expose (public node URL and blockchain RID).

# Full URL including port, e.g. https://node1.chromia.com:7740
VITE_CHROMIA_NODE_URL=https://node1.chromia.com:7740

# 32-byte hex string identifying the MNA dApp blockchain
VITE_CHROMIA_BRID=<your-blockchain-rid-here>
